import pandas as pd
import numpy as np

class RelianceSlateFinancialModel:
    def __init__(self):
        self.assumptions = {
            'initial_smb_customers': 10000,
            'initial_enterprise': 100,
            'monthly_smb_growth': 0.12,
            'monthly_enterprise_growth': 0.08,
            'smb_monthly_price': 2999,
            'enterprise_monthly_price': 49999,
            'smb_monthly_churn': 0.02,
            'enterprise_monthly_churn': 0.005,
            'cac_smb': 3500,
            'cac_enterprise': 20000,
            'monthly_cogs_per_smb': 250,
            'monthly_cogs_per_enterprise': 4000,
            'monthly_opex_base': 2000000,
            'opex_growth_rate': 0.04,
            'network_leverage': 0.35,
        }
    
    def generate_projections(self, months=36):
        # Version-compatible date range
        try:
            # For pandas >= 2.2.0
            dates = pd.date_range(start='2024-04-01', periods=months, freq='ME')
        except:
            # For pandas < 2.2.0
            dates = pd.date_range(start='2024-04-01', periods=months, freq='M')
        
        smb_customers = np.zeros(months)
        enterprise_customers = np.zeros(months)
        smb_customers[0] = self.assumptions['initial_smb_customers']
        enterprise_customers[0] = self.assumptions['initial_enterprise']
        
        monthly_new_smb = np.zeros(months)
        monthly_new_enterprise = np.zeros(months)
        
        for i in range(1, months):
            new_smb = smb_customers[i-1] * self.assumptions['monthly_smb_growth']
            churned_smb = smb_customers[i-1] * self.assumptions['smb_monthly_churn']
            smb_customers[i] = smb_customers[i-1] + new_smb - churned_smb
            monthly_new_smb[i] = new_smb
            
            new_enterprise = enterprise_customers[i-1] * self.assumptions['monthly_enterprise_growth']
            churned_enterprise = enterprise_customers[i-1] * self.assumptions['enterprise_monthly_churn']
            enterprise_customers[i] = enterprise_customers[i-1] + new_enterprise - churned_enterprise
            monthly_new_enterprise[i] = new_enterprise
        
        total_customers = smb_customers + enterprise_customers
        smb_revenue = smb_customers * self.assumptions['smb_monthly_price']
        enterprise_revenue = enterprise_customers * self.assumptions['enterprise_monthly_price']
        total_revenue = smb_revenue + enterprise_revenue
        
        cogs = (smb_customers * self.assumptions['monthly_cogs_per_smb'] + 
                enterprise_customers * self.assumptions['monthly_cogs_per_enterprise'])
        
        cac_smb_effective = self.assumptions['cac_smb'] * (1 - self.assumptions['network_leverage'])
        cac_enterprise_effective = self.assumptions['cac_enterprise'] * (1 - self.assumptions['network_leverage'])
        cac_total = (monthly_new_smb * cac_smb_effective + 
                    monthly_new_enterprise * cac_enterprise_effective)
        
        opex = self.assumptions['monthly_opex_base'] * (1 + self.assumptions['opex_growth_rate']) ** (np.arange(months) / 12)
        
        gross_profit = total_revenue - cogs
        operating_profit = gross_profit - cac_total - opex
        
        return pd.DataFrame({
            'Month': dates.strftime('%Y-%m'),
            'Total_Revenue': np.round(total_revenue, 0),
            'Total_Customers': total_customers.astype(int),
            'Gross_Margin': np.round(gross_profit / total_revenue, 4),
            'Operating_Margin': np.round(operating_profit / total_revenue, 4),
        })
